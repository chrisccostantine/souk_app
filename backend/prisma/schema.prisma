generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum ShopStatus {
  DRAFT
  ACTIVE
  PAUSED
  SUSPENDED
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PACKING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum FulfillmentMethod {
  DELIVERY
  PICKUP
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  CARD_ON_DELIVERY
  WALLET
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum PlacementStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum CampaignChannel {
  PUSH
  WHATSAPP
  EMAIL
}

enum CollaborationStatus {
  PROPOSED
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String?
  passwordSalt String?
  phone        String?
  role         UserRole   @default(CUSTOMER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  shops        Shop[]
  orders       Order[]
  addresses    Address[]
  reviews      Review[]
  favorites    Favorite[]
  storeFollows  StoreFollow[]
  loyaltyAccounts LoyaltyAccount[]
  deviceTokens DeviceToken[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String
  city      String
  line1     String
  line2     String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shop {
  id            String     @id @default(cuid())
  ownerId       String
  name          String
  slug          String     @unique
  category      String
  city          String
  story         String
  status        ShopStatus @default(DRAFT)
  rating        Float      @default(0)
  orderCount    Int        @default(0)
  minimumOrder  Decimal    @default(0)
  deliveryLabel String     @default("Delivery available")
  logoUrl       String?
  bannerUrl     String?
  primaryColor  String?
  accentColor   String?
  instagramUrl  String?
  tiktokUrl     String?
  websiteUrl    String?
  whatsappPhone String?
  contactEmail  String?
  storefrontCollectionIds String[] @default([])
  shopifyMenu   Json?
  shippingPolicy String?
  returnPolicy   String?
  verified      Boolean    @default(false)
  verificationNote String?
  subscriptionPlan SubscriptionPlan @default(FREE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  owner         User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products      Product[]
  orders        Order[]
  reviews       Review[]
  followers     StoreFollow[]
  loyaltyAccounts LoyaltyAccount[]
  notificationCampaigns NotificationCampaign[]
  sponsoredPlacements SponsoredPlacement[]
  analyticsDaily StoreAnalyticsDaily[]
  deliveryRegions DeliveryRegion[]
  liveEvents LiveSellingEvent[]
  affiliateLinks AffiliateLink[]
  collections   Collection[]
  stories       StoreStory[]
  shopifyConnection ShopifyConnection?
}

model StoreStory {
  id        String   @id @default(cuid())
  shopId    String
  title     String
  caption   String?
  imageUrl  String?
  createdAt DateTime @default(now())
  expiresAt DateTime
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([shopId, createdAt])
}

model Product {
  id          String      @id @default(cuid())
  shopId      String
  name        String
  slug        String
  category    String
  description String
  price       Decimal
  compareAtPrice Decimal?
  stock       Int         @default(0)
  active      Boolean     @default(true)
  featured    Boolean     @default(false)
  rating      Float       @default(0)
  imageUrl    String?
  shopifyProductId String?
  shopifyVariantId String?
  shopifyInventoryItemId String?
  shopifyLocationId String?
  syncedFrom  String?
  lastSyncedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  shop        Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  favorites   Favorite[]
  collections ProductCollection[]
  images      ProductImage[]
  variants    ProductVariant[]
  sponsoredPlacements SponsoredPlacement[]

  @@unique([shopId, slug])
  @@index([shopifyInventoryItemId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, url])
  @@index([productId])
}

model ProductVariant {
  id                     String   @id @default(cuid())
  productId              String
  title                  String
  price                  Decimal
  compareAtPrice         Decimal?
  stock                  Int      @default(0)
  sku                    String?
  option1                String?
  option2                String?
  option3                String?
  shopifyVariantId       String?
  shopifyInventoryItemId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  product                Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, shopifyVariantId])
  @@index([shopifyInventoryItemId])
}

model Collection {
  id                String              @id @default(cuid())
  shopId            String
  title             String
  slug              String
  description       String?
  imageUrl          String?
  shopifyCollectionId String?
  collectionType    String              @default("MANUAL")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  shop              Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products          ProductCollection[]

  @@unique([shopId, slug])
}

model ProductCollection {
  productId    String
  collectionId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
}

model ShopifyConnection {
  id          String   @id @default(cuid())
  shopId      String   @unique
  shopDomain  String
  accessToken String
  refreshToken String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scopes      String?
  apiVersion  String   @default("2026-01")
  defaultLocationId String?
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Order {
  id                String            @id @default(cuid())
  customerId        String
  shopId            String
  status            OrderStatus       @default(PLACED)
  fulfillmentMethod FulfillmentMethod @default(DELIVERY)
  paymentMethod     PaymentMethod     @default(CASH_ON_DELIVERY)
  subtotal          Decimal
  deliveryFee       Decimal           @default(0)
  total             Decimal
  deliveryAddress   String?
  note              String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  customer          User              @relation(fields: [customerId], references: [id])
  shop              Shop              @relation(fields: [shopId], references: [id])
  items             OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model StoreFollow {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([shopId])
}

model LoyaltyAccount {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  points    Int      @default(0)
  tier      String   @default("Member")
  referralCode String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
}

model NotificationCampaign {
  id        String          @id @default(cuid())
  shopId    String
  channel   CampaignChannel @default(PUSH)
  title     String
  message   String
  audience  String          @default("followers")
  scheduledAt DateTime?
  sentAt    DateTime?
  deliveredCount Int        @default(0)
  failedCount Int           @default(0)
  createdAt DateTime        @default(now())
  shop      Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String?
  enabled   Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([enabled])
}

model SponsoredPlacement {
  id        String          @id @default(cuid())
  shopId    String
  productId String?
  title     String
  placement String          @default("home")
  budget    Decimal         @default(0)
  status    PlacementStatus @default(DRAFT)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime        @default(now())
  shop      Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product   Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([status, placement])
}

model StoreAnalyticsDaily {
  id        String   @id @default(cuid())
  shopId    String
  day       DateTime
  views     Int      @default(0)
  clicks    Int      @default(0)
  addToCarts Int     @default(0)
  orders    Int      @default(0)
  revenue   Decimal  @default(0)
  bestProductId String?
  topCity   String?
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, day])
}

model DeliveryRegion {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  ruleType  String   @default("REGION")
  minOrder  Decimal?
  maxOrder  Decimal?
  fee       Decimal  @default(0)
  eta       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model LiveSellingEvent {
  id        String   @id @default(cuid())
  shopId    String
  title     String
  startsAt  DateTime
  streamUrl String?
  active    Boolean  @default(false)
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model AffiliateLink {
  id        String              @id @default(cuid())
  shopId    String
  creatorName String
  creatorHandle String?
  code      String
  commissionRate Decimal       @default(0)
  status    CollaborationStatus @default(PROPOSED)
  createdAt DateTime            @default(now())
  shop      Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, code])
}
